import threading
import time
import serial

PORT = "COM5"     # change this to your Arduino COM port
BAUD = 9600

latest_pedal = None
lock = threading.Lock()

def serial_reader():
    global latest_pedal
    ser = serial.Serial(PORT, BAUD, timeout=0.1)
    time.sleep(2)  # Arduino often resets when serial opens

    while True:
        line = ser.readline().decode("utf-8", errors="ignore").strip()
        if not line:
            continue
        try:
            pedal = int(line)
            if 1 <= pedal <= 100:
                with lock:
                    latest_pedal = pedal
        except ValueError:
            pass  # ignore junk lines

threading.Thread(target=serial_reader, daemon=True).start()

# Example "simulation loop" at 60 FPS
while True:
    with lock:
        pedal = latest_pedal

    if pedal is not None:
        # Map 1..100 to 0..1 for throttle-like usage
        throttle = (pedal - 1) / 99.0
        # Use pedal/throttle in your sim update
        print(f"pedal={pedal:3d} throttle={throttle:.3f}")

    time.sleep(1/60)